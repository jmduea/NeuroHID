{
  "version": "2026-02-v2",
  "paths": [
    {
      "pattern": "crates/neurohid-ipc/**",
      "owner": "runtime-ipc",
      "checks": ["cargo-check-ipc", "cargo-test-ipc", "protocol-contracts"],
      "docs": ["docs/runtime-ml-protocol-v2.md", "docs/SPECIFICATION.md", "CHANGELOG.md"]
    },
    {
      "pattern": "crates/neurohid-types/**",
      "owner": "shared-types",
      "checks": ["cargo-check-types", "cargo-test-types", "protocol-contracts"],
      "docs": ["docs/runtime-ml-protocol-v2.md", "docs/SPECIFICATION.md", "CHANGELOG.md"]
    },
    {
      "pattern": "crates/neurohid-core/**",
      "owner": "runtime-core",
      "checks": ["cargo-check-core", "cargo-test-core"],
      "docs": ["README.md", "docs/SPECIFICATION.md", "CHANGELOG.md"]
    },
    {
      "pattern": "crates/neurohid-hub/**",
      "owner": "hub-ui",
      "checks": ["cargo-check-hub", "cargo-test-hub"],
      "docs": ["README.md", "docs/ux/interaction-checklist.md", "CHANGELOG.md"]
    },
    {
      "pattern": "crates/neurohid-platform/**",
      "owner": "platform",
      "checks": ["cargo-check-platform", "cargo-test-platform", "unsafe-compliance"],
      "docs": ["README.md", "docs/SPECIFICATION.md", "CHANGELOG.md"]
    },
    {
      "pattern": "python/src/**",
      "owner": "python-ml",
      "checks": ["python-quality", "python-tests"],
      "docs": ["python/README.md", "docs/runtime-ml-protocol-v2.md", "CHANGELOG.md"]
    },
    {
      "pattern": "python/notebooks/**",
      "owner": "python-notebooks",
      "checks": ["python-quality", "python-tests"],
      "docs": ["python/notebooks/README.md", "python/README.md", "CHANGELOG.md"]
    },
    {
      "pattern": "docs/runtime-ml-protocol-v2.md",
      "owner": "protocol-docs",
      "checks": ["protocol-contracts"],
      "docs": ["docs/runtime-ml-protocol-v2.md", "docs/SPECIFICATION.md", "CHANGELOG.md"]
    },
    {
      "pattern": "docs/SPECIFICATION.md",
      "owner": "spec",
      "checks": ["docs-freshness"],
      "docs": ["docs/SPECIFICATION.md", "README.md", "CHANGELOG.md"]
    },
    {
      "pattern": ".github/agents/**",
      "owner": "automation",
      "checks": ["agent-routing-integrity"],
      "docs": ["AGENTS.md", "docs/automation/agent-skill-invocation-playbook.md", "CHANGELOG.md"]
    },
    {
      "pattern": ".github/hooks/**",
      "owner": "automation",
      "checks": ["agent-routing-integrity"],
      "docs": ["AGENTS.md", "docs/automation/agent-skill-invocation-playbook.md", "CHANGELOG.md"]
    }
  ]
}
