{
  "$schema": "../hooks.schema.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "(?s).+",
        "agents": [
          "deep-executor",
          "verifier",
          "writer",
          "completion-finisher"
        ]
      },
      {
        "matcher": "(?i)(rust|cargo)",
        "agents": [
          "rust-skill-router"
        ]
      }
    ]
  }
}
