{
  "$schema": "./hooks.schema.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "(?i)(docs|documentation|readme|spec|changelog|stale docs|doc drift|protocol doc)",
        "agents": [
          "writer"
        ]
      },
      {
        "matcher": "(?i)(architecture|adr|boundary|layering|cross-crate|protocol compatibility|storage format|migration)",
        "agents": [
          "architect",
          "api-reviewer",
          "writer"
        ]
      },
      {
        "matcher": "(?i)(feature planning|feature brief|roadmap|milestone|epic|scope|definition of ready|definition of done)",
        "agents": [
          "product-manager",
          "planner"
        ]
      },
      {
        "matcher": "(?i)(tdd|tests first|test-driven|add tests|failing test|regression test)",
        "agents": [
          "test-engineer",
          "verifier"
        ]
      },
      {
        "matcher": "(?i)(ux|ui|usability|interaction|onboarding|accessibility|notebook workflow|docs ux)",
        "agents": [
          "ux-researcher",
          "designer",
          "writer"
        ]
      },
      {
        "matcher": "(?i)(python|ml|deep learning|eegnet|decoder|errp|inference|training|notebook)",
        "agents": [
          "scientist",
          "test-engineer",
          "writer"
        ]
      },
      {
        "matcher": "(?i)(\\brust\\b|\\bcargo\\b|rustc|crate|Cargo\\.toml|\\.rs\\b|ownership|borrow|lifetime|trait|generic|async|await|tokio|serde|axum|unsafe|ffi|E0\\d{3,4}|value moved|cannot borrow|does not live long enough|mismatched types|not satisfied|Send|Sync)",
        "agents": [
          "rust-skill-router"
        ]
      },
      {
        "matcher": "(?i)(\\brtk\\b|rust token killer|token reduction|token savings|command rewrite|prefix commands with rtk|rtk init|rtk gain)",
        "agents": [
          "deep-executor"
        ]
      },
      {
        "matcher": "(?i)(implement|implementation|fix|refactor|coding|code change|finish coding|done coding|ship it|ready to commit|create commit)",
        "agents": [
          "writer",
          "completion-finisher"
        ]
      },
      {
        "matcher": "(?s).+",
        "agents": [
          "deep-executor",
          "verifier",
          "writer",
          "completion-finisher"
        ]
      }
    ]
  }
}
